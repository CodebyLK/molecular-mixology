<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Masterclass: Acid-Adjustment</title>
    <link rel="stylesheet" href="/css/terminal.css">
    
</head>
<body>
    <div class="terminal-container">
        <header>
            <h1><a href="/dashboard" style="color: var(--text-muted); text-decoration: none; font-size: 1.5rem;">&lt; Back</a> | Masterclass: Acid-Adjustment</h1>
            <p>Engineer citrus profiles to create the perfectly balanced backbone of a cocktail.</p>
        </header>

        <main>
            <form action="/modules/acid/calculate" method="POST" class="module-card" style="max-width: 550px; margin: 0 auto;">
                
                <h3 style="margin-bottom: 2rem; text-align: center; font-size: 1.8rem;">Configure Your Batch</h3>

                <div class="form-group">
                    <label for="baseJuice">Base Liquid (The Canvas)</label>
                    <select name="baseJuice" id="baseJuice" class="elegant-input" required>
                        <% Object.keys(juices).forEach(key => { %>
                            <option value="<%= key %>"><%= juices[key].name %> (Current Acid: <%= juices[key].currentAcid %>%)</option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="targetProfile">Target Profile (The Goal)</label>
                    <select name="targetProfile" id="targetProfile" class="elegant-input" required>
                        <% Object.keys(targets).forEach(key => { %>
                            <option value="<%= key %>"><%= targets[key].name %> (Target Acid: <%= targets[key].targetAcid %>%)</option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="volumeMl">Batch Volume (in ml)</label>
                    <input type="number" name="volumeMl" id="volumeMl" class="elegant-input" placeholder="e.g., 500" required min="10">
                </div>

                <button type="submit" style="margin-top: 1rem; width: 100%;">
                    Calculate Formula
                </button>
            </form>
        </main>
    </div>
</body>
</html>
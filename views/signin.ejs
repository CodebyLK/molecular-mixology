<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speakeasy | Laboratory Login</title>
    <link rel="stylesheet" href="/css/terminal.css">
    <link rel="stylesheet" href="/css/pantry.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Fira+Code&display=swap" rel="stylesheet">
</head>
<body style="display: flex; align-items: center; justify-content: center; height: 100vh; background: #050505;">

<div class="ai-result-panel" style="width: 100%; max-width: 400px; border-radius: 8px;">
    <div class="report-header">
        <h3 style="letter-spacing: 2px;">SECURE ACCESS</h3>
        <span class="report-id">AUTH: REQUIRED</span>
    </div>
    <hr class="lab-divider">

    <p class="lab-subtitle" style="font-size: 0.9rem; margin-bottom: 2rem;">Provide your credentials to engage the molecular synthesis engine.</p>

    <form action="/signin" method="POST">
        <div class="control-group" style="flex-direction: column; align-items: flex-start; margin-bottom: 1.5rem;">
            <label style="font-size: 0.9rem; margin-bottom: 0.5rem;">Laboratory Email</label>
            <input type="email" name="email" required style="width: 100%; background: #000; border: 1px solid rgba(212, 175, 55, 0.4); padding: 12px; color: #fff; font-family: 'Fira Code', monospace; border-radius: 4px;">
        </div>

        <div class="control-group" style="flex-direction: column; align-items: flex-start; margin-bottom: 2rem;">
            <label style="font-size: 0.9rem; margin-bottom: 0.5rem;">Access Code</label>
            <input type="password" name="password" required style="width: 100%; background: #000; border: 1px solid rgba(212, 175, 55, 0.4); padding: 12px; color: #fff; font-family: 'Fira Code', monospace; border-radius: 4px;">
        </div>

        <button type="submit" class="protocol-btn" style="width: 100%;">Unlock Laboratory</button>
    </form>

    <p style="margin-top: 1.5rem; font-size: 0.8rem; color: #888; text-align: center;">
        New to the Speakeasy? <a href="/signup" style="color: #d4af37; text-decoration: none;">Apply for Access</a>
    </p>
</div>

</body>
</html>
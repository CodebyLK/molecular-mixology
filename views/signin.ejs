<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speakeasy | Establish Credentials</title>

    <link rel="stylesheet" href="/css/terminal.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<%- include('partials/header') %>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-icon">🍸</div>
        <h1>The Speakeasy</h1>
        <p>Establish credentials to access the laboratory.</p>

        <form action="/signin" method="POST" class="auth-form">

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="auth-input" placeholder="alchemist@example.com" required autocomplete="email">
            </div>

            <div class="form-group">
                <label for="password">Passphrase</label>
                <input type="password" id="password" name="password" class="auth-input" placeholder="••••••••" required>
            </div>

            <button type="submit" class="auth-btn">Gain Entry</button>
        </form>

        <div class="auth-links">
            Don't have an invitation? <a href="/signup">Request Access</a>
        </div>
    </div>
</div>

</body>
</html>
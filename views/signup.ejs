<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speakeasy | Request Access</title>

    <link rel="stylesheet" href="/css/terminal.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<%- include('partials/header') %>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-icon">🗝️</div>
        <h1>Request Access</h1>
        <p>Register your credentials to enter the speakeasy.</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-msg" style="color: #ef4444; background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); padding: 12px; margin-bottom: 20px; border-radius: 4px; font-size: 0.85rem; text-align: center;">
                <%= error %>
            </div>
        <% } %>

        <form action="/signup" method="POST" class="auth-form">

            <div class="form-group">
                <label for="name">Alias / Name</label>
                <input type="text" id="name" name="username" class="auth-input" placeholder="The Alchemist" required>
            </div>

            <div class="form-group">
                <label for="email">Secure Email</label>
                <input type="email" id="email" name="email" class="auth-input" placeholder="alchemist@example.com" required>
            </div>

            <div class="form-group">
                <label for="password">Passphrase</label>
                <input type="password" id="password" name="password" class="auth-input" placeholder="••••••••" required minlength="6">
            </div>

            <button type="submit" class="auth-btn">Submit Credentials</button>
        </form>

        <div class="auth-links">
            Already hold a membership? <a href="/signin">Gain Entry</a>
        </div>
    </div>
</div>

</body>
</html>
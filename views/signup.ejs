<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speakeasy | Lab Registration</title>
    <link rel="stylesheet" href="/css/terminal.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Fira+Code&display=swap" rel="stylesheet">
</head>
<body class="auth-body">

<div class="auth-panel">
    <div class="auth-header">
        <h3 class="auth-title">NEW RECRUIT</h3>
        <span class="auth-id">SEC-ORD: 001</span>
    </div>

    <p class="auth-subtitle">Apply for laboratory credentials to access the Alchemist's Database.</p>

    <form action="/signup" method="POST">
        <div class="auth-control-group">
            <label for="usernameInput" class="auth-label">Username</label>
            <input id="usernameInput" type="text" name="username" required class="auth-input">
        </div>

        <div class="auth-control-group">
            <label for="emailInput" class="auth-label">Email Address</label>
            <input id="emailInput" type="email" name="email" required class="auth-input">
        </div>

        <div class="auth-control-group">
            <label for="passwordInput" class="auth-label">Access Code</label>
            <input id="passwordInput" type="password" name="password" required class="auth-input">
        </div>

        <button type="submit" class="auth-btn">Authorize Account</button>
    </form>

    <p class="auth-footer-text">
        Already credentialed? <a href="/signin" class="auth-link">Unlock Vault</a>
    </p>
</div>

</body>
</html>